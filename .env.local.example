# Neon Postgres (Vercel Storage가 자동 주입. 로컬은 vercel env pull 또는 수동.)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# 외부 API 호출(Custom GPT Actions, curl 등)에 쓰는 Bearer 토큰
JARVIS_API_TOKEN="generate-a-random-uuid-here"

# 웹 UI 로그인용 비밀번호 (Bearer 토큰과 분리해서 보관)
JARVIS_WEB_PASSWORD="generate-another-random-uuid-here"

# Google Calendar 연동 (단계 2 완료 후 채워짐)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"
